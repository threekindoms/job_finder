# ── Ollama (local inference server) ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Local prefilter models ────────────────────────────────────────────────────
# Comma-separated list in priority order.
# First two run for every job; third is the tiebreaker when they disagree.
LOCAL_PREFILTER_MODELS=llama3.1:8b,mistral:7b-instruct,deepseek-r1:7b

# ── Ollama cloud (remote Ollama endpoint) ────────────────────────────────────
# OLLAMA_CLOUD_BASE_URL=https://api.ollama.com
# OLLAMA_CLOUD_API_KEY=

# Cloud prefilter models — comma-separated, added to the prefilter pool alongside
# LOCAL_PREFILTER_MODELS. Leave unset to use only local models.
# CLOUD_PREFILTER_MODELS=llama3.3:70b,qwen2.5:72b

# ── Shortlist scoring (final matching step) ───────────────────────────────────
# Provider: ollama | ollama_cloud | anthropic | openai | google
SHORTLIST_SCORING_PROVIDER=ollama
SHORTLIST_SCORING_MODEL=llama3.1:8b

# ── Shortlist caps ────────────────────────────────────────────────────────────
JOB_TEXT_MAX_CHARS=10000
MAX_PAID_LLM_JOBS=20
SKIP_PAID_LLM_IF_LOCAL_SCORE_BELOW=70

# ── Run output ────────────────────────────────────────────────────────────────
RUNS_DIR=runs

# ── Persistent store ──────────────────────────────────────────────────────────
# STORAGE_DB_PATH=storage/store.db
# BACKUP_DB_PATH=~/Documents/Storages/resume_matching

# ── Cloud provider credentials ────────────────────────────────────────────────
# Uncomment the block for the provider you want to use for shortlist scoring
# and set SHORTLIST_SCORING_PROVIDER / SHORTLIST_SCORING_MODEL above to match.

# -- Anthropic --
# SHORTLIST_SCORING_PROVIDER=anthropic
# SHORTLIST_SCORING_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=

# -- OpenAI --
# SHORTLIST_SCORING_PROVIDER=openai
# SHORTLIST_SCORING_MODEL=gpt-4o-mini
# OPENAI_API_KEY=

# -- Google --
# SHORTLIST_SCORING_PROVIDER=google
# SHORTLIST_SCORING_MODEL=gemini-2.0-flash
# GOOGLE_API_KEY=

# -- Ollama cloud --
# SHORTLIST_SCORING_PROVIDER=ollama_cloud
# SHORTLIST_SCORING_MODEL=llama3.3:70b
# (set OLLAMA_CLOUD_BASE_URL and OLLAMA_CLOUD_API_KEY in the section above)
